rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
       return request.auth != null;
    }
    
    function isOwner(userId) {
       return isAuthenticated() && request.auth.uid == userId;
    }

    // Verifica si el usuario es participante de un chat basado en el ID del chat (formato uid1_uid2)
    function isChatParticipant(chatId) {
      return isAuthenticated() && (chatId.matches('^' + request.auth.uid + '_.*') || chatId.matches('.*_' + request.auth.uid + '$'));
    }

    // Validación básica de campos permitidos
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    // 1. Usuarios: Solo el dueño puede escribir su perfil. 
    // Lectura: Solo autenticados (necesario para buscar contactos).
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isOwner(userId);
      
      // Subcolecciones privadas del usuario
      match /contacts/{contactId} {
        allow read, write: if isOwner(userId);
      }

      match /starred/{messageId} {
        allow read, write: if isOwner(userId);
      }

      match /blocked/{blockedId} {
        allow read, write: if isOwner(userId);
      }
    }
    
    // 2. Chats y Mensajes: Solo los participantes pueden leer o escribir.
    match /chats/{chatId} {
      // Permitir acceso al documento del chat si eres participante
      allow read: if isChatParticipant(chatId);

      match /messages/{messageId} {
        allow read: if isChatParticipant(chatId);
        
        // Solo el remitente puede crear el mensaje y debe ser participante
        allow create: if isChatParticipant(chatId) && 
                        request.resource.data.senderId == request.auth.uid;
        
        // Solo el remitente puede borrar o editar sus propios mensajes
        allow update, delete: if isChatParticipant(chatId) && 
                                resource.data.senderId == request.auth.uid;
      }

      match /typing/{userId} {
        allow read: if isChatParticipant(chatId);
        allow write: if isOwner(userId) && isChatParticipant(chatId);
      }
    }

    // 3. Soporte, Reportes y Feedback: Privacidad total.
    match /support_tickets/{ticketId} {
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    match /reports/{reportId} {
      allow create: if isAuthenticated() && request.resource.data.reporterId == request.auth.uid;
      // Lectura denegada para usuarios normales (solo admin vía consola/backend)
    }

    match /feedback/{feedbackId} {
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      // Lectura denegada para usuarios normales
    }
  }
}
